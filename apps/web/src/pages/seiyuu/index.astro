---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'
import Avatar from '../../components/Avatar.astro'
const apiBase = process.env.API_URL || 'http://localhost:3001'

const currentPage = Number(Astro.url.searchParams.get('page') ?? 1)
const limit = 24

interface SeiyuuData {
  data: {
    id: string
    nameRomaji: string
    nameKanji: string | null
    imageUrl: string | null
    agency: string | null
    isSinger: boolean | null
    isActive: boolean | null
  }[]
  page: number
  limit: number
  total: number
  totalPages: number
}

let data: SeiyuuData = { data: [], page: 1, limit, total: 0, totalPages: 1 }

try {
  const res = await fetch(`${apiBase}/api/v1/seiyuu?page=${currentPage}&limit=${limit}`)
  if (res.ok) data = await res.json()
} catch {}
---

<BaseLayout title='Seiyuu — seiyuu.db'>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  <div class='max-w-4xl mx-auto px-6 py-10'>
    <div class='mb-8'>
      <h1 class='text-2xl font-medium mb-2'>Seiyuu</h1>
      <p class='text-sm text-neutral-400'>{data.total} voice actors indexed</p>
    </div>

    <form action='/search' method='GET' id='search-form' class='relative flex items-center gap-3 border border-neutral-700 rounded-lg px-4 py-3 mb-6 focus-within:border-teal-600 transition-colors'>
      <span class='text-neutral-500 text-lg'>🔍</span>
      <input type='text' id='search-input' name='q' placeholder='Search by name...' autocomplete='off'
        class='flex-1 bg-transparent outline-none text-sm placeholder:text-neutral-600' />
      <div id='search-results' class='absolute top-full left-0 right-0 mt-1 border border-neutral-700 rounded-md bg-neutral-950 max-h-60 overflow-y-auto z-10 hidden'></div>
    </form>

    <div class='grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4'>
      {data.data.map((s) => (
        <a href={`/seiyuu/${s.id}`}
          class='border border-neutral-800 rounded-xl overflow-hidden hover:border-neutral-600 transition-colors'>
          <div class='aspect-square bg-neutral-900 flex items-center justify-center overflow-hidden'>
            {s.imageUrl ? (
              <img src={s.imageUrl} alt={s.nameRomaji} class='w-full h-full object-cover' />
            ) : (
              <div class='w-16 h-16 rounded-full bg-teal-900/60 flex items-center justify-center text-lg font-medium text-teal-300'>
                {s.nameRomaji.split(' ').map(w => w.charAt(0)).join('').toUpperCase().slice(0, 2)}
              </div>
            )}
          </div>
          <div class='p-3'>
            <div class='text-sm font-medium truncate'>{s.nameRomaji}</div>
            <div class='text-xs text-neutral-500 mt-0.5 truncate'>{s.nameKanji ?? s.agency ?? ''}</div>
          </div>
        </a>
      ))}
    </div>

    {data.totalPages > 1 && (
      <div class='flex items-center justify-center gap-3 mt-8'>
        {currentPage > 1 && (
          <a href={`/seiyuu?page=${currentPage - 1}`} class='text-sm px-4 py-2 rounded-md border border-neutral-700 bg-neutral-900 text-neutral-300 hover:border-neutral-500'>
            &larr; Previous
          </a>
        )}
        <span class='text-sm text-neutral-400'>Page {currentPage} of {data.totalPages}</span>
        {currentPage < data.totalPages && (
          <a href={`/seiyuu?page=${currentPage + 1}`} class='text-sm px-4 py-2 rounded-md border border-neutral-700 bg-neutral-900 text-neutral-300 hover:border-neutral-500'>
            Next &rarr;
          </a>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const searchInput = document.getElementById('search-input') as HTMLInputElement
  const searchResults = document.getElementById('search-results')!
  const searchForm = document.getElementById('search-form')!
  let searchTimer: any

  searchInput.addEventListener('input', () => {
    clearTimeout(searchTimer)
    const q = searchInput.value.trim()
    if (q.length < 2) { searchResults.classList.add('hidden'); return }
    searchTimer = setTimeout(async () => {
      const res = await fetch(`/api/v1/search?q=${encodeURIComponent(q)}&limit=6`)
      if (!res.ok) { searchResults.classList.add('hidden'); return }
      const data = await res.json()
      const items = data.results || []
      searchResults.innerHTML = items.length
        ? items.map((s: any) => `
          <a href='/seiyuu/${s.id}' class='flex items-center gap-3 px-3 py-2 text-sm hover:bg-neutral-800 cursor-pointer'>
            ${s.imageUrl ? `<img src='${s.imageUrl}' class='w-8 h-8 rounded-full object-cover flex-shrink-0' />` : `<div class='w-8 h-8 rounded-full bg-teal-900/60 flex items-center justify-center text-xs font-medium text-teal-300 flex-shrink-0'>${(s.nameRomaji || '?').charAt(0)}</div>`}
            <div class='flex-1 min-w-0'>
              <div class='text-sm truncate'>${s.nameRomaji}</div>
              <div class='text-xs text-neutral-500 truncate'>${s.nameKanji ?? ''}</div>
            </div>
          </a>
        `).join('')
        : '<div class="px-3 py-2 text-sm text-neutral-500">No results</div>'
      searchResults.classList.remove('hidden')
    }, 250)
  })

  document.addEventListener('click', (e) => {
    if (!searchForm.contains(e.target as Node)) {
      searchResults.classList.add('hidden')
    }
  })
</script>
