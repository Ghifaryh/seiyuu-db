---
import BaseLayout from '../../layouts/BaseLayout.astro'

const API_BASE = 'http://localhost:3001/api/v1'
---

<BaseLayout title='Admin login — seiyuu.db'>
  <div class='min-h-screen flex items-center justify-center px-6'>
    <div class='w-full max-w-sm'>
      <a href='/' class='flex items-center gap-2.5 justify-center mb-8'>
        <div class='w-[34px] h-[34px] rounded-lg bg-teal-600 flex items-center justify-center text-[10px] font-medium text-teal-50 flex-shrink-0'>
          seiyuu
        </div>
        <div class='text-[17px] font-medium tracking-tight'>
          seiyuu<span class='text-teal-400'>.db</span>
        </div>
      </a>

      <div class='border border-neutral-800 rounded-xl p-6 bg-neutral-900/50'>
        <h1 class='text-lg font-medium mb-1 text-center'>Admin sign in</h1>
        <p class='text-sm text-neutral-400 text-center mb-6'>Restricted access — staff only</p>

        <form id='login-form' class='flex flex-col gap-4'>
          <div>
            <label for='email' class='text-sm text-neutral-400 block mb-1.5'>Email</label>
            <input type='email' id='email' required placeholder='admin@seiyuu.db'
              class='w-full text-sm px-3.5 py-2.5 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />
          </div>

          <div>
            <label for='password' class='text-sm text-neutral-400 block mb-1.5'>Password</label>
            <input type='password' id='password' required placeholder='••••••••'
              class='w-full text-sm px-3.5 py-2.5 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />
          </div>

          <p id='error-msg' class='text-sm text-red-400 hidden'></p>

          <button type='submit'
            class='text-sm px-4 py-2.5 rounded-md bg-teal-600 text-teal-50 font-medium hover:bg-teal-500 mt-2'>
            Sign in
          </button>
        </form>
      </div>

      <p class='text-xs text-neutral-600 text-center mt-6'>
        <a href='/' class='hover:text-neutral-400'>&larr; Back to seiyuu.db</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  const API_BASE = 'http://localhost:3001/api/v1'
  const form = document.getElementById('login-form') as HTMLFormElement
  const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    errorMsg.classList.add('hidden')

    const email = (document.getElementById('email') as HTMLInputElement).value
    const password = (document.getElementById('password') as HTMLInputElement).value

    try {
      const res = await fetch(`${API_BASE}/auth/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      })

      if (!res.ok) {
        const data = await res.json()
        errorMsg.textContent = data.message || 'Invalid credentials'
        errorMsg.classList.remove('hidden')
        return
      }

      const data = await res.json()
      if (data.user.role !== 'admin' && data.user.role !== 'superadmin') {
        errorMsg.textContent = 'Not an admin account'
        errorMsg.classList.remove('hidden')
        return
      }

      localStorage.setItem('seiyuu_token', data.token)
      localStorage.setItem('seiyuu_user', JSON.stringify(data.user))
      window.location.href = '/admin'
    } catch {
      errorMsg.textContent = 'Connection failed — is the API running?'
      errorMsg.classList.remove('hidden')
    }
  })
</script>
