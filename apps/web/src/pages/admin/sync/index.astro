---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import AdminGuard from '../../../components/admin/AdminGuard.astro'
---

<AdminGuard />
<AdminLayout title='Sync — seiyuu.db admin'>
  <div class='px-8 py-8 max-w-4xl'>
    <div class='flex items-center justify-between mb-8'>
      <div>
        <h1 class='text-2xl font-medium mb-1'>Sync</h1>
        <p class='text-sm text-neutral-400'>Pull data from AniList</p>
      </div>
    </div>

    <div id='seasons-grid' class='flex flex-col gap-8'></div>
  </div>
</AdminLayout>

<script>
  const API_BASE = '/api/v1'
  const QUARTERS = ['winter', 'spring', 'summer', 'fall']
  const QUARTER_LABELS: Record<string, string> = { winter: 'Winter', spring: 'Spring', summer: 'Summer', fall: 'Fall' }
  const YEARS = [2026, 2025, 2024]

  function getAuthHeaders() {
    const token = localStorage.getItem('seiyuu_token')
    return token ? { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' } : {}
  }

  async function triggerSync(year: number, quarter: string, el: HTMLElement) {
    el.innerHTML = 'Syncing...'
    el.classList.add('text-amber-400')
    const res = await fetch(`${API_BASE}/sync/season/${year}/${quarter}`, { method: 'POST', headers: getAuthHeaders() })
    if (res.ok) {
      el.textContent = 'Started ✓'
      el.classList.remove('text-amber-400')
      el.classList.add('text-teal-400')
      // sync runs in background — the ✓ just means the job started
      setTimeout(() => loadSeasons(), 5000)
    } else {
      el.textContent = 'Failed ✗'
      el.classList.add('text-red-400')
    }
  }

  async function loadSeasons() {
    const grid = document.getElementById('seasons-grid')!
    grid.innerHTML = '<div class="text-sm text-neutral-500">Loading...</div>'

    const seasonData: Record<string, { year: number; quarter: string; count: number; isCurrent: boolean }[]> = {}

    const now = new Date()
    const currentMonth = now.getMonth() + 1
    const currentYear = now.getFullYear()
    let currentQuarter = 'winter'
    if (currentMonth >= 4 && currentMonth <= 6) currentQuarter = 'spring'
    else if (currentMonth >= 7 && currentMonth <= 9) currentQuarter = 'summer'
    else if (currentMonth >= 10) currentQuarter = 'fall'

    // Check all seasons
    for (const year of YEARS) {
      seasonData[year] = []
      for (const q of QUARTERS) {
        try {
          const res = await fetch(`${API_BASE}/season/${year}/${q}?limit=1`)
          const data = res.ok ? await res.json() : null
          seasonData[year].push({
            year, quarter: q,
            count: data?.total ?? 0,
            isCurrent: year === currentYear && q === currentQuarter
          })
        } catch {
          seasonData[year].push({ year, quarter: q, count: 0, isCurrent: false })
        }
        await new Promise(r => setTimeout(r, 150))
      }
    }

    grid.innerHTML = YEARS.map(year => {
      const seasons = seasonData[year] || []
      return `
        <div>
          <h2 class='text-sm font-medium text-neutral-400 mb-3'>${year}</h2>
          <div class='grid grid-cols-2 md:grid-cols-4 gap-4'>
            ${seasons.map(s => `
              <div class='border border-neutral-800 rounded-xl p-5 bg-neutral-900/50 relative
                ${s.count > 0 ? 'border-l-teal-600 border-l-2' : ''}
                ${s.isCurrent ? 'border-l-amber-600 border-l-2' : ''}'>
                <div class='flex items-center justify-between mb-3'>
                  <span class='text-sm font-medium'>${QUARTER_LABELS[s.quarter]}</span>
                  ${s.isCurrent ? '<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-amber-900/50 text-amber-300">current</span>' : ''}
                </div>
                <div class='text-2xl font-medium ${s.count > 0 ? 'text-teal-400' : 'text-neutral-600'} mb-1'>${s.count || '—'}</div>
                <div class='text-xs text-neutral-500 mb-4'>anime synced</div>
                <button data-sync='${year}-${s.quarter}'
                  class='sync-btn text-xs px-3 py-1.5 rounded-md w-full
                  ${s.count > 0
                    ? 'border border-teal-700 text-teal-400 hover:bg-teal-950/30'
                    : 'bg-teal-600 text-teal-50 hover:bg-teal-500'}'>
                  ${s.count > 0 ? 'Re-sync' : 'Sync'}
                </button>
              </div>
            `).join('')}
          </div>
        </div>`
    }).join('')

    document.querySelectorAll('.sync-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation()
        const [y, q] = btn.getAttribute('data-sync')!.split('-')
        await triggerSync(Number(y), q, btn as HTMLElement)
      })
    })
  }

  loadSeasons()
</script>
