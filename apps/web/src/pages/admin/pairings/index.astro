---
import AdminLayout from '../../../layouts/AdminLayout.astro'

// mock data for now — will be replaced with a real fetch to /api/v1/pairings
const pairings = [
	{
		id: 'sao-duo',
		nameA: 'Yoshitsugu Matsuoka',
		nameB: 'Ai Kayano',
		initialsA: 'YM',
		initialsB: 'AK',
		pairName: 'The SAO Duo',
		sharedCount: 8,
		isAutoDetected: false,
	},
	{
		id: 'kamiya-yuuki',
		nameA: 'Hiroshi Kamiya',
		nameB: 'Aoi Yuuki',
		initialsA: 'HK',
		initialsB: 'AY',
		pairName: 'Kamiya & Yuuki',
		sharedCount: 11,
		isAutoDetected: true,
	},
	{
		id: 'hanazawa-miyano',
		nameA: 'Kana Hanazawa',
		nameB: 'Mamoru Miyano',
		initialsA: 'KH',
		initialsB: 'MM',
		pairName: null,
		sharedCount: 7,
		isAutoDetected: true,
	},
	{
		id: 'kaji-hanazawa',
		nameA: 'Yuki Kaji',
		nameB: 'Kana Hanazawa',
		initialsA: 'YK',
		initialsB: 'KH',
		pairName: 'Kaji & Hanazawa',
		sharedCount: 9,
		isAutoDetected: false,
	},
]
---

<AdminLayout title='Manage pairings — seiyuu.db'>
	<div class='px-5 md:px-8 py-6 md:py-8 max-w-5xl'>
		<div class='flex items-center justify-between mb-6 flex-wrap gap-3'>
			<div>
				<h1 class='text-2xl font-medium mb-1'>Pairings</h1>
				<p class='text-sm text-neutral-400'>
					{pairings.length} dynamic duos in database
				</p>
			</div>
			<a
				href='/admin/pairings/new'
				class='text-sm px-4 py-2 rounded-md bg-teal-600 text-teal-50 font-medium hover:bg-teal-500 flex items-center gap-1.5'
			>
				<i class='ti ti-plus text-base'></i>
				New pairing
			</a>
		</div>

		<div class='flex items-center gap-2 mb-5'>
			<button
				data-filter='all'
				class='filter-btn text-sm px-3 py-2 rounded-md bg-teal-900/50 text-teal-300 font-medium'
				>All</button
			>
			<button
				data-filter='named'
				class='filter-btn text-sm px-3 py-2 rounded-md text-neutral-400 hover:bg-neutral-900'
				>Named only</button
			>
			<button
				data-filter='auto'
				class='filter-btn text-sm px-3 py-2 rounded-md text-neutral-400 hover:bg-neutral-900'
				>Auto-detected</button
			>
		</div>

		<div class='border border-neutral-800 rounded-xl overflow-hidden'>
			<div
				class='hidden md:grid grid-cols-[1fr_120px_100px_60px] gap-3 px-5 py-3 border-b border-neutral-800 bg-neutral-900/50 text-xs text-neutral-500 font-medium uppercase tracking-wide'
			>
				<span>Pairing</span>
				<span>Shared anime</span>
				<span>Source</span>
				<span></span>
			</div>

			<div id='pairing-rows'>
				{
					pairings.map((p) => (
						<div
							class='pairing-row grid grid-cols-1 md:grid-cols-[1fr_120px_100px_60px] gap-2 md:gap-3 px-5 py-3.5 border-b border-neutral-800 last:border-b-0 items-center'
							data-source={p.isAutoDetected ? 'auto' : 'named'}
						>
							<div class='flex items-center gap-3'>
								<div class='flex items-center'>
									<div class='w-8 h-8 rounded-full bg-teal-900/60 flex items-center justify-center text-[10px] font-medium text-teal-300 border-2 border-neutral-950'>
										{p.initialsA}
									</div>
									<div class='w-8 h-8 rounded-full bg-purple-900/60 flex items-center justify-center text-[10px] font-medium text-purple-300 border-2 border-neutral-950 -ml-2.5'>
										{p.initialsB}
									</div>
								</div>
								<div>
									<div class='text-sm font-medium'>
										{p.pairName ??
											`${p.nameA} & ${p.nameB}`}
									</div>
									<div class='text-xs text-neutral-500'>
										{p.nameA} & {p.nameB}
									</div>
								</div>
							</div>
							<div class='text-sm text-neutral-400'>
								{p.sharedCount} anime
							</div>
							<div>
								{p.isAutoDetected ? (
									<span class='text-xs px-2 py-0.5 rounded-full bg-neutral-800 text-neutral-400'>
										Auto-detected
									</span>
								) : (
									<span class='text-xs px-2 py-0.5 rounded-full bg-teal-900/50 text-teal-300'>
										Named
									</span>
								)}
							</div>
							<a
								href={`/admin/pairings/${p.id}`}
								class='text-sm text-teal-400 hover:text-teal-300 justify-self-start md:justify-self-end'
							>
								Edit
							</a>
						</div>
					))
				}
			</div>
		</div>
	</div>
</AdminLayout>

<script>
	const filterButtons = document.querySelectorAll('.filter-btn')
	const rows = document.querySelectorAll('.pairing-row')

	filterButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter')

			filterButtons.forEach((b) => {
				b.classList.remove(
					'bg-teal-900/50',
					'text-teal-300',
					'font-medium',
				)
				b.classList.add('text-neutral-400')
			})
			btn.classList.remove('text-neutral-400')
			btn.classList.add('bg-teal-900/50', 'text-teal-300', 'font-medium')

			rows.forEach((row) => {
				const source = row.getAttribute('data-source')
				if (filter === 'all' || source === filter) {
					row.classList.remove('hidden')
				} else {
					row.classList.add('hidden')
				}
			})
		})
	})
</script>
