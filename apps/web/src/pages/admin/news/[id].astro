---
export const prerender = false

import AdminSplitLayout from '../../../layouts/AdminSplitLayout.astro'
import AdminGuard from '../../../components/admin/AdminGuard.astro'

const { id } = Astro.params
const isNewEditor = id === 'new'
---

<AdminGuard />
<AdminSplitLayout title={isNewEditor ? 'New post — seiyuu.db admin' : 'Edit post — seiyuu.db admin'} previewUrl={isNewEditor ? undefined : `/news/${id}`}>
  <div class='px-8 py-8 max-w-2xl'>
    <a href='/admin/news' class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'>
      &larr; Back to news
    </a>

    <h1 class='text-2xl font-medium mb-8'>{isNewEditor ? 'New post' : 'Edit post'}</h1>

    <div id='edit-form' class='flex flex-col gap-4'>
      <input id='edit-title' placeholder='Title' class='text-sm px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />

      <label class='flex items-center gap-2 cursor-pointer w-fit'>
        <input type='checkbox' id='has-body-toggle' class='rounded border-neutral-700 bg-neutral-950 accent-teal-600' checked />
        <span class='text-sm text-neutral-400'>Has body content</span>
      </label>

      <textarea id='edit-body' rows='6' placeholder='Body text...' class='text-sm px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600'></textarea>

      <div class='flex gap-4'>
        <select id='edit-category' class='text-sm px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white'>
          <option value='roles'>Role announcement</option>
          <option value='agency'>Agency news</option>
        </select>
      </div>

      <div>
        <label class='text-xs text-neutral-500 block mb-1.5'>Tagged seiyuu</label>
        <div id='seiyuu-tags' class='flex flex-wrap gap-1 mb-2'></div>
        <div class='relative'>
          <input type='text' id='edit-seiyuu-search' placeholder='Search seiyuu to tag...' autocomplete='off'
            class='text-sm w-full px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />
          <div id='seiyuu-results' class='absolute top-full left-0 right-0 mt-1 border border-neutral-700 rounded-md bg-neutral-950 max-h-40 overflow-y-auto z-10 hidden'></div>
        </div>
      </div>

      <div>
        <input id='edit-source' placeholder='Source URL (required if no body)' class='text-sm w-full px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />
        <p id='source-hint' class='text-xs text-neutral-500 mt-1 hidden'>Source URL is required when body is empty</p>
      </div>

      <div>
        <input id='edit-fb-post' placeholder='Facebook post URL (embed)' type='url'
          class='text-sm w-full px-3 py-2 rounded-md border border-neutral-700 bg-neutral-950 text-white placeholder:text-neutral-600 outline-none focus:border-teal-600' />
        <p class='text-xs text-neutral-500 mt-1'>Paste a Facebook post URL to embed it on the public page</p>
      </div>

      <p id='edit-error' class='text-sm text-red-400 hidden'></p>
      <p id='edit-success' class='text-sm text-teal-400 hidden'></p>

      <button id='save-btn' class='text-sm px-4 py-2 rounded-md bg-teal-600 text-teal-50 font-medium hover:bg-teal-500 w-fit'>
        {isNewEditor ? 'Publish' : 'Save changes'}
      </button>
    </div>
  </div>
</AdminSplitLayout>

<script>
  const API_BASE = '/api/v1'
  const pathParts = window.location.pathname.split('/')
  const postId = pathParts[pathParts.length - 1]
  const isNew = postId === 'new'

  function getAuthHeaders() {
    const token = localStorage.getItem('seiyuu_token')
    return token ? { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' } : {}
  }

  function normalizeUrl(url: string): string | null {
    const u = url.trim()
    if (!u) return null
    if (u.startsWith('http://') || u.startsWith('https://')) return u
    return 'https://' + u
  }

  const bodyEl = document.getElementById('edit-body') as HTMLTextAreaElement
  const sourceInput = document.getElementById('edit-source') as HTMLInputElement
  const hasBodyToggle = document.getElementById('has-body-toggle') as HTMLInputElement
  const sourceHint = document.getElementById('source-hint') as HTMLParagraphElement
  const fbPostInput = document.getElementById('edit-fb-post') as HTMLInputElement
  const taggedSeiyuu: { id: string; name: string }[] = []

  function renderTags() {
    const container = document.getElementById('seiyuu-tags')!
    container.innerHTML = taggedSeiyuu.map(s => `
      <span class='inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full bg-teal-900/50 text-teal-300'>
        ${s.name}
        <button class='remove-tag text-teal-300 hover:text-red-400 ml-0.5' data-id='${s.id}'>&times;</button>
      </span>
    `).join('')
    container.querySelectorAll('.remove-tag').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id')!
        const idx = taggedSeiyuu.findIndex(s => s.id === id)
        if (idx >= 0) taggedSeiyuu.splice(idx, 1)
        renderTags()
      })
    })
  }

  function toggleBody() {
    const hasBody = hasBodyToggle.checked
    bodyEl.classList.toggle('hidden', !hasBody)
    sourceHint.classList.toggle('hidden', hasBody)
  }

  hasBodyToggle.addEventListener('change', toggleBody)

  async function loadPost() {
    if (isNew) return
    const ctrl = new AbortController()
    const t = setTimeout(() => ctrl.abort(), 8000)
    try {
      const res = await fetch(`${API_BASE}/news/${postId}`, { signal: ctrl.signal })
      clearTimeout(t)
      if (!res.ok) return
      const p = await res.json()
      if (p.message) return
      ;(document.getElementById('edit-title') as HTMLInputElement).value = p.title || ''
      ;(document.getElementById('edit-category') as HTMLSelectElement).value = p.category || 'roles'
      sourceInput.value = p.sourceUrl || ''
      fbPostInput.value = p.fbPostUrl || ''
      taggedSeiyuu.length = 0
      if (p.seiyuus?.length) {
        taggedSeiyuu.push(...p.seiyuus.map((s: any) => ({ id: s.id, name: s.nameRomaji })))
        renderTags()
      }
      if (p.body) {
        bodyEl.value = p.body
        hasBodyToggle.checked = true
      } else {
        hasBodyToggle.checked = false
        toggleBody()
      }
    } catch {
      clearTimeout(t)
    }
  }

  loadPost()

  loadPost()

  // seiyuu search picker
  const seiyuuSearch = document.getElementById('edit-seiyuu-search') as HTMLInputElement
  const seiyuuResults = document.getElementById('seiyuu-results')!
  let seiyuuTimer: any

  seiyuuSearch.addEventListener('input', () => {
    clearTimeout(seiyuuTimer)
    const q = seiyuuSearch.value.trim()
    if (q.length < 2) { seiyuuResults.classList.add('hidden'); return }
    seiyuuTimer = setTimeout(async () => {
      const res = await fetch(`/api/v1/search?q=${encodeURIComponent(q)}&limit=6`)
      if (!res.ok) { seiyuuResults.classList.add('hidden'); return }
      const data = await res.json()
      const items = data.results || []
      seiyuuResults.innerHTML = items.length
        ? items.map((s: any) => `<div class='flex items-center gap-2 px-3 py-2 text-sm hover:bg-neutral-800 cursor-pointer' data-id="${s.id}" data-name="${s.nameRomaji}">${s.imageUrl ? `<img src="${s.imageUrl}" class="w-6 h-6 rounded-full object-cover" />` : ''}${s.nameRomaji} ${s.nameKanji ? `<span class="text-neutral-500 text-xs">${s.nameKanji}</span>` : ''}</div>`).join('')
        : '<div class="px-3 py-2 text-sm text-neutral-500">No results</div>'
      seiyuuResults.querySelectorAll('div[data-id]').forEach(el => {
        el.addEventListener('click', () => {
          const id = el.getAttribute('data-id')!
          const name = el.getAttribute('data-name')!
          if (!taggedSeiyuu.find(s => s.id === id)) {
            taggedSeiyuu.push({ id, name })
            renderTags()
          }
          seiyuuSearch.value = ''
          seiyuuResults.classList.add('hidden')
        })
      })
      seiyuuResults.classList.remove('hidden')
    }, 250)
  })
  document.addEventListener('click', e => {
    if (!seiyuuSearch.contains(e.target as Node) && !seiyuuResults.contains(e.target as Node)) {
      seiyuuResults.classList.add('hidden')
    }
  })

  document.getElementById('save-btn')?.addEventListener('click', async () => {
    const title = (document.getElementById('edit-title') as HTMLInputElement).value.trim()
    const body = bodyEl.value.trim()
    const category = (document.getElementById('edit-category') as HTMLSelectElement).value
    const seiyuuIds = taggedSeiyuu.length > 0 ? taggedSeiyuu.map(s => s.id) : undefined
    const sourceUrl = normalizeUrl(sourceInput.value)
    const fbPostUrl = fbPostInput.value.trim() || undefined
    const errorEl = document.getElementById('edit-error')!
    const successEl = document.getElementById('edit-success')!

    errorEl.classList.add('hidden')
    successEl.classList.add('hidden')

    if (!title) {
      errorEl.textContent = 'Title is required'; errorEl.classList.remove('hidden')
      return
    }
    if (!body && !sourceUrl) {
      errorEl.textContent = 'Either body content or a source URL is required'; errorEl.classList.remove('hidden')
      return
    }

    if (isNew) {
      const user = JSON.parse(localStorage.getItem('seiyuu_user') || '{}')
      const res = await fetch(`${API_BASE}/news`, {
        method: 'POST', headers: getAuthHeaders(),
        body: JSON.stringify({ title, body: body || undefined, category, seiyuuIds, sourceUrl: sourceUrl || undefined, fbPostUrl, createdBy: user.id }),
      })
      if (res.ok) {
        successEl.textContent = 'Published! Redirecting...'
        successEl.classList.remove('hidden')
        const data = await res.json()
        setTimeout(() => { window.location.href = '/admin/news' }, 800)
      } else {
        const data = await res.json()
        errorEl.textContent = data.message || 'Failed to create'
        errorEl.classList.remove('hidden')
      }
    } else {
      const res = await fetch(`${API_BASE}/news/${postId}`, {
        method: 'PATCH', headers: getAuthHeaders(),
        body: JSON.stringify({ title, body: body || undefined, category, seiyuuIds: seiyuuIds || undefined, sourceUrl: sourceUrl || undefined, fbPostUrl: fbPostUrl || undefined }),
      })
      if (res.ok) {
        successEl.textContent = 'Saved!'
        successEl.classList.remove('hidden')
        setTimeout(() => successEl.classList.add('hidden'), 2000)
        const frame = document.getElementById('preview-frame') as HTMLIFrameElement | null
        if (frame) frame.src = frame.src
      } else {
        const data = await res.json()
        errorEl.textContent = data.message || 'Failed to save'
        errorEl.classList.remove('hidden')
      }
    }
  })
</script>
