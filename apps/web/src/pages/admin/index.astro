---
import AdminLayout from '../../layouts/AdminLayout.astro'
import AdminGuard from '../../components/admin/AdminGuard.astro'
---

<AdminGuard />
<AdminLayout title='Admin overview — seiyuu.db'>
  <div class='px-8 py-8 max-w-5xl'>
    <h1 class='text-2xl font-medium mb-1'>Overview</h1>
    <p class='text-sm text-neutral-400 mb-8'>Quick glance at your database</p>

    <div id='stats-grid' class='grid grid-cols-2 md:grid-cols-4 gap-4 mb-10'>
      <div class='border border-neutral-800 rounded-xl p-4 bg-neutral-900/50'>
        <i class='ti ti-users text-teal-400 text-xl mb-2'></i>
        <div class='text-2xl font-medium' id='stat-seiyuu'>—</div>
        <div class='text-xs text-neutral-500 mt-1'>Total seiyuu</div>
      </div>
      <div class='border border-neutral-800 rounded-xl p-4 bg-neutral-900/50'>
        <i class='ti ti-movie text-teal-400 text-xl mb-2'></i>
        <div class='text-2xl font-medium' id='stat-anime'>—</div>
        <div class='text-xs text-neutral-500 mt-1'>Total anime</div>
      </div>
      <div class='border border-neutral-800 rounded-xl p-4 bg-neutral-900/50'>
        <i class='ti ti-heart text-teal-400 text-xl mb-2'></i>
        <div class='text-2xl font-medium' id='stat-pairings'>—</div>
        <div class='text-xs text-neutral-500 mt-1'>Pairings</div>
      </div>
      <div class='border border-neutral-800 rounded-xl p-4 bg-neutral-900/50'>
        <i class='ti ti-news text-teal-400 text-xl mb-2'></i>
        <div class='text-2xl font-medium' id='stat-news'>—</div>
        <div class='text-xs text-neutral-500 mt-1'>News posts</div>
      </div>
    </div>

    <div class='flex items-center justify-between mb-4'>
      <h2 class='text-base font-medium'>Quick actions</h2>
    </div>

    <div class='grid grid-cols-1 md:grid-cols-2 gap-4'>
      <a href='/admin/news' class='border border-neutral-800 rounded-xl p-5 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
        <i class='ti ti-news text-teal-400 text-xl mb-2'></i>
        <div class='text-sm font-medium mb-1'>Manage news</div>
        <div class='text-xs text-neutral-500'>Create, edit, delete news posts</div>
      </a>
      <a href='/admin/seiyuu' class='border border-neutral-800 rounded-xl p-5 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
        <i class='ti ti-users text-teal-400 text-xl mb-2'></i>
        <div class='text-sm font-medium mb-1'>Manage seiyuu</div>
        <div class='text-xs text-neutral-500'>Edit profiles, add enrichment data</div>
      </a>
      <a href='/admin/pairings' class='border border-neutral-800 rounded-xl p-5 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
        <i class='ti ti-heart text-teal-400 text-xl mb-2'></i>
        <div class='text-sm font-medium mb-1'>Manage pairings</div>
        <div class='text-xs text-neutral-500'>Create manual pairings</div>
      </a>
      <div class='border border-neutral-800 rounded-xl p-5 bg-neutral-900/50'>
        <i class='ti ti-refresh text-teal-400 text-xl mb-2'></i>
        <div class='text-sm font-medium mb-1'>Sync data</div>
        <div class='text-xs text-neutral-500'>Sync from AniList — coming soon in admin</div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const API_BASE = 'http://localhost:3001/api/v1'

  async function loadStats() {
    try {
      const [seiyuuRes, newsRes] = await Promise.all([
        fetch(`${API_BASE}/seiyuu?limit=1`),
        fetch(`${API_BASE}/news?limit=1`),
      ])
      const seiyuuData = await seiyuuRes.json()
      const newsData = await newsRes.json()

      document.getElementById('stat-seiyuu')!.textContent = seiyuuData.total ?? '—'
      document.getElementById('stat-news')!.textContent = newsData.length ?? '—'

      const pairRes = await fetch(`${API_BASE}/pairings?limit=1`)
      const pairData = await pairRes.json()
      document.getElementById('stat-pairings')!.textContent = pairData.length ?? '—'
      document.getElementById('stat-anime')!.textContent = '—' // need count endpoint
    } catch {}
  }

  loadStats()
</script>
