---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Avatar from '../../components/Avatar.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'
import { formatSeason } from '../../lib/api'

const { id } = Astro.params

interface AnimeDetail {
  id: string
  titleRomaji: string
  titleNative: string | null
  studio: string | null
  status: string | null
  coverUrl: string | null
  seasonYear: number | null
  seasonQuarter: string | null
  cast: {
    roleId: string
    roleType: string | null
    language: string | null
    character: { id: string; nameRomaji: string; nameKanji: string | null }
    seiyuu: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null }
  }[]
}

let anime: AnimeDetail | null = null
let error = ''

try {
  const res = await fetch(`http://localhost:3001/api/v1/anime/${id}`)
  if (res.ok) anime = await res.json()
  else error = 'Anime not found'
} catch {
  error = 'Failed to load anime'
}

const season = anime ? formatSeason(anime.seasonYear, anime.seasonQuarter) : ''
---

<BaseLayout title={anime ? `${anime.titleRomaji} — seiyuu.db` : 'Not Found — seiyuu.db'}>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  {error || !anime ? (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <h1 class='text-2xl font-medium'>{error}</h1>
    </div>
  ) : (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <a href={anime.seasonYear && anime.seasonQuarter ? `/season/${anime.seasonYear}/${anime.seasonQuarter}` : '/season'}
        class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'>
        <i class='ti ti-arrow-left text-base'></i>
        Back to season
      </a>

      <div class='flex gap-6 mb-8'>
        {anime.coverUrl ? (
          <img src={anime.coverUrl} alt={anime.titleRomaji} class='w-28 h-40 rounded-xl object-cover border border-neutral-800 flex-shrink-0' />
        ) : (
          <div class='w-28 h-40 rounded-xl bg-neutral-900 border border-neutral-800 flex items-center justify-center flex-shrink-0'>
            <i class='ti ti-photo text-neutral-600 text-2xl'></i>
          </div>
        )}
        <div class='flex-1'>
          <h1 class='text-2xl font-medium mb-1'>{anime.titleRomaji}</h1>
          {anime.titleNative && <p class='text-sm text-neutral-400 mb-3'>{anime.titleNative}</p>}

          <div class='flex flex-wrap gap-2 mb-4'>
            {anime.studio && (
              <span class='text-sm px-3 py-1 rounded-full border border-neutral-700 bg-neutral-900 text-neutral-300'>
                <i class='ti ti-building text-sm' style='vertical-align:-2px'></i> {anime.studio}
              </span>
            )}
            <span class='text-sm px-3 py-1 rounded-full border border-neutral-700 bg-neutral-900 text-neutral-300'>
              <i class='ti ti-calendar text-sm' style='vertical-align:-2px'></i> {season}
            </span>
            <span class={`text-sm px-3 py-1 rounded-full flex items-center gap-1.5 ${anime.status === 'releasing' || anime.status === 'airing' ? 'bg-teal-900/50 text-teal-300' : 'bg-neutral-800 text-neutral-400'}`}>
              {anime.status === 'releasing' || anime.status === 'airing' ? (
                <><span class='w-1.5 h-1.5 rounded-full bg-teal-400' /> Airing</>
              ) : (
                (anime.status ?? 'unknown').charAt(0).toUpperCase() + (anime.status ?? 'unknown').slice(1)
              )}
            </span>
          </div>
        </div>
      </div>

      {anime.cast.length > 0 && (
        <>
          <p class='text-sm font-medium uppercase tracking-wide text-neutral-500 mb-4'>Voice cast</p>
          <div class='flex flex-col gap-2'>
            {anime.cast.map((c) => (
              <a href={`/seiyuu/${c.seiyuu.id}`}
                class='flex items-center gap-4 border border-neutral-800 rounded-lg px-4 py-3 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
                <Avatar name={c.seiyuu.nameRomaji} imageUrl={c.seiyuu.imageUrl} size='md' />
                <div class='flex-1'>
                  <div class='text-sm font-medium'>{c.character.nameRomaji}</div>
                  {c.character.nameKanji && <div class='text-xs text-neutral-500 mt-0.5'>{c.character.nameKanji}</div>}
                </div>
                <div class='text-right'>
                  <div class='text-sm font-medium text-neutral-300'>{c.seiyuu.nameRomaji}</div>
                  {c.roleType === 'main' ? (
                    <span class='text-xs px-2 py-0.5 rounded-full bg-teal-900/50 text-teal-300 mt-1 inline-block'>Main</span>
                  ) : (
                    <span class='text-xs px-2 py-0.5 rounded-full bg-neutral-800 text-neutral-400 mt-1 inline-block'>Support</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  )}
</BaseLayout>
