---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'

const { id } = Astro.params

// mock data for now — will be replaced with a real fetch to /api/v1/anime/:id
const anime = {
	title: 'Mushoku Tensei: Jobless Reincarnation III',
	titleNative: '無職転生 III',
	studio: 'Studio Bind',
	status: 'airing',
	episode: 8,
	totalEpisodes: 12,
	season: 'Spring 2026',
	synopsis:
		'Rudeus continues his journey through a world of magic, navigating new relationships and dangers as he works toward reuniting with those he holds dear. Season three picks up shortly after the events of the previous arc.',
	cast: [
		{
			character: 'Rudeus Greyrat',
			characterJp: 'ルーデウス・グレイラット',
			role: 'main',
			seiyuu: 'Yuki Kaji',
			seiyuuSlug: 'yuki-kaji',
			initials: 'YK',
		},
		{
			character: 'Zenith Greyrat',
			characterJp: 'ゼニス・グレイラット',
			role: 'supporting',
			seiyuu: 'Ai Kayano',
			seiyuuSlug: 'ai-kayano',
			initials: 'AK',
		},
		{
			character: 'Paul Greyrat',
			characterJp: 'パウロ・グレイラット',
			role: 'supporting',
			seiyuu: 'Tomokazu Sugita',
			seiyuuSlug: 'tomokazu-sugita',
			initials: 'TS',
		},
		{
			character: 'Sylphiette',
			characterJp: 'シルフィエット',
			role: 'main',
			seiyuu: 'Rina Ohta',
			seiyuuSlug: 'rina-ohta',
			initials: 'RO',
		},
	],
}
---

<BaseLayout title={`${anime.title} — seiyuu.db`}>
	<Nav slot='nav' />
	<NewsTicker slot='nav' />

	<div class='max-w-3xl mx-auto px-6 py-10'>
		<a
			href='/season'
			class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'
		>
			<i class='ti ti-arrow-left text-base'></i>
			Back to season
		</a>

		<div class='flex gap-6 mb-8'>
			<div
				class='w-28 h-40 rounded-xl bg-neutral-900 border border-neutral-800 flex items-center justify-center flex-shrink-0'
			>
				<i class='ti ti-photo text-neutral-600 text-2xl'></i>
			</div>
			<div class='flex-1'>
				<h1 class='text-2xl font-medium mb-1'>{anime.title}</h1>
				<p class='text-sm text-neutral-400 mb-3'>{anime.titleNative}</p>

				<div class='flex flex-wrap gap-2 mb-4'>
					<span
						class='text-sm px-3 py-1 rounded-full border border-neutral-700 bg-neutral-900 text-neutral-300'
					>
						<i
							class='ti ti-building text-sm'
							style='vertical-align:-2px'></i>
						{anime.studio}
					</span>
					<span
						class='text-sm px-3 py-1 rounded-full border border-neutral-700 bg-neutral-900 text-neutral-300'
					>
						<i
							class='ti ti-calendar text-sm'
							style='vertical-align:-2px'></i>
						{anime.season}
					</span>
					{
						anime.status === 'airing' ? (
							<span class='text-sm px-3 py-1 rounded-full bg-teal-900/50 text-teal-300 flex items-center gap-1.5'>
								<span class='w-1.5 h-1.5 rounded-full bg-teal-400' />
								Ep {anime.episode} of {anime.totalEpisodes}
							</span>
						) : (
							<span class='text-sm px-3 py-1 rounded-full bg-neutral-800 text-neutral-400'>
								Upcoming
							</span>
						)
					}
				</div>

				<p class='text-sm text-neutral-400 leading-relaxed'>
					{anime.synopsis}
				</p>
			</div>
		</div>

		<p
			class='text-sm font-medium uppercase tracking-wide text-neutral-500 mb-4'
		>
			Voice cast
		</p>

		<div class='flex flex-col gap-2'>
			{
				anime.cast.map((c) => (
					<a
						href={`/seiyuu/${c.seiyuuSlug}`}
						class='flex items-center gap-4 border border-neutral-800 rounded-lg px-4 py-3 bg-neutral-900/50 hover:border-neutral-600 transition-colors'
					>
						<div class='w-10 h-10 rounded-full bg-teal-900/60 flex items-center justify-center text-sm font-medium text-teal-300 flex-shrink-0'>
							{c.initials}
						</div>
						<div class='flex-1'>
							<div class='text-sm font-medium'>{c.character}</div>
							<div class='text-xs text-neutral-500 mt-0.5'>
								{c.characterJp}
							</div>
						</div>
						<div class='text-right'>
							<div class='text-sm font-medium text-neutral-300'>
								{c.seiyuu}
							</div>
							{c.role === 'main' ? (
								<span class='text-xs px-2 py-0.5 rounded-full bg-teal-900/50 text-teal-300 mt-1 inline-block'>
									Main
								</span>
							) : (
								<span class='text-xs px-2 py-0.5 rounded-full bg-neutral-800 text-neutral-400 mt-1 inline-block'>
									Support
								</span>
							)}
						</div>
					</a>
				))
			}
		</div>
	</div>
</BaseLayout>
