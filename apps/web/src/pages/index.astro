---
import BaseLayout from '../layouts/BaseLayout.astro'
import Nav from '../components/layout/Nav.astro'
import NewsTicker from '../components/layout/NewsTicker.astro'

interface SeiyuuCard {
  id: string
  nameRomaji: string
  nameKanji: string | null
  imageUrl: string | null
  roleCount: number
}

let popular: SeiyuuCard[] = []
try {
  const res = await fetch('http://localhost:3001/api/v1/season/current/seiyuu')
  if (res.ok) {
    const data = await res.json() as { data: SeiyuuCard[] }
    popular = data.data?.slice(0, 10) ?? []
  }
} catch {
  // API not available, keep empty
}
---

<BaseLayout title='seiyuu.db — Find any voice actor'>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  <div class='max-w-3xl mx-auto px-6 py-16'>
    <div class='text-center mb-10'>
      <h1 class='text-4xl font-medium leading-snug mb-3'>
        The seiyuu database<br />built for <span class='text-teal-400'>real fans</span>
      </h1>
      <p class='text-base text-neutral-400'>
        Search by kanji, romaji, or any name order — we'll figure it out
      </p>
    </div>

    <form action='/search' method='GET' class='flex items-center gap-3 border-2 border-teal-600 rounded-xl px-5 py-4 mb-4'>
      <span class='text-teal-500 text-xl'>🔍</span>
      <input
        type='text'
        name='q'
        placeholder='茅野愛衣 · Kayano Ai · Ai Kayano...'
        class='flex-1 bg-transparent outline-none text-base placeholder:text-neutral-500'
      />
    </form>

    <div class='flex gap-2 flex-wrap mb-12 justify-center'>
      {['Kanji & kana', 'Flexible name order', 'Romaji', 'Fuzzy match'].map((hint) => (
        <span class='text-sm px-3 py-1 rounded-full border border-neutral-700 bg-neutral-900 text-neutral-300'>
          ✓ {hint}
        </span>
      ))}
    </div>

    {popular.length > 0 && (
      <>
        <p class='text-sm font-medium uppercase tracking-wide text-neutral-500 mb-4'>
          Popular this season
        </p>
        <div class='grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-4'>
          {popular.map((va) => (
            <a
              href={`/seiyuu/${va.id}`}
              class='border border-neutral-800 rounded-xl overflow-hidden hover:border-neutral-600 transition-colors'
            >
              <div class='aspect-[2/3] bg-neutral-900 flex items-center justify-center border-b border-neutral-800 overflow-hidden'>
                {va.imageUrl ? (
                  <img src={va.imageUrl} alt={va.nameRomaji} class='w-full h-full object-cover' />
                ) : (
                  <div class='w-16 h-16 rounded-full bg-teal-900/60 flex items-center justify-center text-lg font-medium text-teal-300'>
                    {va.nameRomaji.split(' ').map(w => w.charAt(0)).join('').toUpperCase().slice(0, 2)}
                  </div>
                )}
              </div>
              <div class='p-3'>
                <div class='text-sm font-medium'>{va.nameRomaji}</div>
                <div class='text-xs text-neutral-500 mt-1'>
                  {va.nameKanji ?? ''}
                </div>
                <span class='text-xs mt-2 inline-block px-2 py-0.5 rounded-full bg-teal-900/60 text-teal-300'>
                  {va.roleCount} roles
                </span>
              </div>
            </a>
          ))}
        </div>
      </>
    )}
  </div>
</BaseLayout>
