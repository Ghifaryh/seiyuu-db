---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Avatar from '../../components/Avatar.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'

const { id } = Astro.params

interface PairingDetail {
  id: string
  pairName: string | null
  description: string | null
  sharedCount: number
  isAutoDetected: boolean | null
  seiyuuA: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null }
  seiyuuB: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null } | null
  sharedAnime: {
    anime: { id: string; titleRomaji: string; titleNative: string | null; seasonYear: number | null; studio: string | null; coverUrl: string | null }
    charA: { id: string; nameRomaji: string } | null
    charB: { id: string; nameRomaji: string } | null
    roleTypeA: string | null
    roleTypeB: string | null
  }[]
}

let pairing: PairingDetail | null = null
let error = ''

try {
  const res = await fetch(`/api/v1/pairings/${id}`)
  if (res.ok) pairing = await res.json()
  else error = 'Pairing not found'
} catch {
  error = 'Failed to load pairing'
}

const sharedYears = pairing?.sharedAnime.map(a => a.anime.seasonYear).filter(Boolean) as number[] ?? []
const firstYear = sharedYears.length > 0 ? Math.min(...sharedYears) : null
const recentYear = sharedYears.length > 0 ? Math.max(...sharedYears) : null
---

<BaseLayout title={pairing?.pairName ? `${pairing.pairName} — seiyuu.db` : 'Pairing — seiyuu.db'}>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  {error || !pairing ? (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <h1 class='text-2xl font-medium'>{error || 'Pairing not found'}</h1>
    </div>
  ) : (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <div class='border border-neutral-800 rounded-xl p-8 bg-neutral-900/50 mb-8'>
        <div class='flex items-center justify-center gap-0 mb-6'>
          <Avatar name={pairing.seiyuuA.nameRomaji} imageUrl={pairing.seiyuuA.imageUrl} size='lg' />
          <div class='flex flex-col items-center gap-1 px-5'>
            <div class='w-px h-5 bg-neutral-700'></div>
            <div class='w-9 h-9 rounded-full bg-neutral-800 border border-neutral-700 flex items-center justify-center'>
              <i class='ti ti-link text-neutral-400 text-base'></i>
            </div>
            <div class='w-px h-5 bg-neutral-700'></div>
          </div>
          {pairing.seiyuuB ? (
            <Avatar name={pairing.seiyuuB.nameRomaji} imageUrl={pairing.seiyuuB.imageUrl} size='lg' />
          ) : (
            <div class='w-16 h-16 rounded-full bg-neutral-800 flex items-center justify-center text-lg font-medium text-neutral-500 border border-neutral-800'>?</div>
          )}
        </div>

        <div class='flex items-center justify-center gap-6 mb-6'>
          <div class='text-center'>
            <a href={`/seiyuu/${pairing.seiyuuA.id}`} class='text-base font-medium hover:text-teal-400'>{pairing.seiyuuA.nameRomaji}</a>
            <div class='text-xs text-neutral-500 mt-1'>{pairing.seiyuuA.nameKanji}</div>
          </div>
          <span class='text-xl text-neutral-600'>&</span>
          <div class='text-center'>
            {pairing.seiyuuB ? (
              <>
                <a href={`/seiyuu/${pairing.seiyuuB.id}`} class='text-base font-medium hover:text-teal-400'>{pairing.seiyuuB.nameRomaji}</a>
                <div class='text-xs text-neutral-500 mt-1'>{pairing.seiyuuB.nameKanji}</div>
              </>
            ) : (
              <span class='text-base text-neutral-500'>—</span>
            )}
          </div>
        </div>

        <div class='text-center mb-6'>
          <h1 class='text-xl font-medium mb-1'>{pairing.pairName ?? `${pairing.seiyuuA.nameRomaji} & ${pairing.seiyuuB?.nameRomaji ?? '?'}`}</h1>
          {pairing.description && <p class='text-sm text-neutral-400'>{pairing.description}</p>}
        </div>

        <div class='grid grid-cols-3 gap-3'>
          <div class='bg-neutral-900 rounded-lg p-3 text-center'>
            <div class='text-xl font-medium text-teal-400'>{pairing.sharedCount}</div>
            <div class='text-xs text-neutral-500 mt-1'>shared anime</div>
          </div>
          <div class='bg-neutral-900 rounded-lg p-3 text-center'>
            <div class='text-xl font-medium text-teal-400'>{firstYear ?? '—'}</div>
            <div class='text-xs text-neutral-500 mt-1'>first together</div>
          </div>
          <div class='bg-neutral-900 rounded-lg p-3 text-center'>
            <div class='text-xl font-medium text-teal-400'>{recentYear ?? '—'}</div>
            <div class='text-xs text-neutral-500 mt-1'>most recent</div>
          </div>
        </div>
      </div>

      {pairing.sharedAnime.length > 0 && (
        <>
          <p class='text-sm font-medium uppercase tracking-wide text-neutral-500 mb-4'>Shared anime & roles</p>
          <div class='flex flex-col gap-3'>
            {pairing.sharedAnime.map((a) => (
              <div class='border border-neutral-800 rounded-lg overflow-hidden'>
                <div class='flex items-center gap-3 px-4 py-3 bg-neutral-900 border-b border-neutral-800'>
                  <span class='w-2 h-2 rounded-full bg-teal-500 flex-shrink-0' />
                  <a href={`/anime/${a.anime.id}`} class='text-sm font-medium flex-1 hover:text-teal-400'>{a.anime.titleRomaji}</a>
                  <span class='text-xs text-neutral-500'>{a.anime.seasonYear} · {a.anime.studio}</span>
                </div>
                <div class='flex'>
                  <div class='flex items-center gap-3 px-4 py-3 flex-1 border-r border-neutral-800'>
                    <Avatar name={a.charA?.nameRomaji ?? '?'} imageUrl={null} size='sm' />
                    <div>
                      <div class='text-sm font-medium'>{a.charA?.nameRomaji ?? '—'}</div>
                      <div class='text-xs text-neutral-500'>{pairing.seiyuuA.nameRomaji}</div>
                    </div>
                  </div>
                  <div class='flex items-center gap-3 px-4 py-3 flex-1'>
                    <Avatar name={a.charB?.nameRomaji ?? '?'} imageUrl={null} size='sm' />
                    <div>
                      <div class='text-sm font-medium'>{a.charB?.nameRomaji ?? '—'}</div>
                      <div class='text-xs text-neutral-500'>{pairing.seiyuuB?.nameRomaji ?? '—'}</div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </>
      )}
    </div>
  )}
</BaseLayout>
