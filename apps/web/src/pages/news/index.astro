---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Avatar from '../../components/Avatar.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'
const apiBase = process.env.API_URL || 'http://localhost:3001'

interface NewsItem {
  id: string
  title: string
  body: string
  category: string | null
  sourceUrl: string | null
  publishedAt: string | null
  seiyuus: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null }[] | null
}

let newsPosts: NewsItem[] = []
try {
  const res = await fetch(`${apiBase}/api/v1/news?limit=20`)
  if (res.ok) {
    const json = await res.json()
    newsPosts = json.data ?? json
  }
} catch {}

const categoryStyles: Record<string, string> = {
  roles: 'bg-teal-900/50 text-teal-300',
  agency: 'bg-purple-900/50 text-purple-300',
}

function fixUrl(u: string) {
  if (u.startsWith('http://') || u.startsWith('https://')) return u
  return 'https://' + u
}
---

<BaseLayout title='News — seiyuu.db'>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  <div class='max-w-3xl mx-auto px-6 py-10'>
    <div class='mb-8'>
      <h1 class='text-2xl font-medium mb-2'>News</h1>
      <p class='text-sm text-neutral-400'>Role announcements and agency news from across the industry</p>
    </div>

    <div class='flex gap-2 mb-6'>
      <button data-filter='all' class='filter-btn text-sm px-3.5 py-1.5 rounded-md bg-teal-900/50 text-teal-300 font-medium'>All</button>
      <button data-filter='roles' class='filter-btn text-sm px-3.5 py-1.5 rounded-md text-neutral-400 hover:bg-neutral-900'>Roles</button>
      <button data-filter='agency' class='filter-btn text-sm px-3.5 py-1.5 rounded-md text-neutral-400 hover:bg-neutral-900'>Agency</button>
    </div>

    <div id='news-list' class='flex flex-col gap-4'>
      {newsPosts.map((post) => {
        const hasBody = post.body && post.body.trim().length > 0
        const isExternal = !hasBody && post.sourceUrl
        const href = isExternal ? fixUrl(post.sourceUrl!) : `/news/${post.id}`
        const target = isExternal ? '_blank' : ''
        const rel = isExternal ? 'noopener noreferrer' : ''
        return (
        <a href={href} target={target} rel={rel} data-category={post.category ?? ''}
          class='news-item block border border-neutral-800 rounded-xl p-5 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
          <div class='flex items-start gap-4'>
            {post.seiyuus?.length ? (
              <Avatar name={post.seiyuus[0].nameRomaji} imageUrl={post.seiyuus[0].imageUrl} size='md' />
            ) : (
              <div class='w-10 h-10 rounded-full bg-teal-900/60 flex items-center justify-center text-sm font-medium text-teal-300 flex-shrink-0'>?</div>
            )}
            <div class='flex-1'>
              <div class='flex items-center gap-2 mb-2'>
                <span class={`text-xs px-2.5 py-0.5 rounded-full font-medium ${categoryStyles[post.category ?? ''] ?? 'bg-neutral-800 text-neutral-400'}`}>
                  {post.category === 'roles' ? 'Role announcement' : post.category === 'agency' ? 'Agency news' : 'Update'}
                </span>
                <span class='text-xs text-neutral-500'>
                  {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : ''}
                </span>
                {isExternal && (<span class='text-xs text-teal-500'>🔗 external</span>)}
              </div>
              <h2 class='text-base font-medium mb-2 leading-snug'>{post.title}</h2>
              {hasBody ? (
                <p class='text-sm text-neutral-400 leading-relaxed'>{post.body}</p>
              ) : (
                <p class='text-sm text-teal-500'>Read on source →</p>
              )}
            </div>
          </div>
        </a>
        )}
      )}
    </div>
  </div>
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll('.filter-btn')
  const newsItems = document.querySelectorAll('.news-item')

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter')
      filterButtons.forEach((b) => {
        b.classList.remove('bg-teal-900/50', 'text-teal-300', 'font-medium')
        b.classList.add('text-neutral-400')
      })
      btn.classList.remove('text-neutral-400')
      btn.classList.add('bg-teal-900/50', 'text-teal-300', 'font-medium')
      newsItems.forEach((item) => {
        const category = item.getAttribute('data-category')
        if (filter === 'all' || category === filter) {
          item.classList.remove('hidden')
        } else {
          item.classList.add('hidden')
        }
      })
    })
  })
</script>
