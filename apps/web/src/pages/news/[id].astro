---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Avatar from '../../components/Avatar.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'

const apiBase = process.env.API_URL || 'http://localhost:3001'
const { id } = Astro.params

interface Post {
  id: string
  title: string
  body: string
  category: string | null
  sourceUrl: string | null
  fbPostUrl: string | null
  publishedAt: string | null
  seiyuus: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null }[] | null
}

let post: Post | null = null
let error = ''

try {
  const res = await fetch(`${apiBase}/api/v1/news/${id}`)
  if (res.ok) post = await res.json()
  else error = 'News post not found'
} catch {
  error = 'Failed to load news post'
}

const categoryStyles: Record<string, string> = {
  roles: 'bg-teal-900/50 text-teal-300',
  agency: 'bg-purple-900/50 text-purple-300',
}
const categoryLabel: Record<string, string> = {
  roles: 'Role announcement',
  agency: 'Agency news',
}
const formattedDate = post?.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : ''

const hasBody = post?.body && post.body.trim().length > 0
const hasFbEmbed = post?.fbPostUrl && post.fbPostUrl.trim().length > 0

if (post && !hasBody && !hasFbEmbed && post.sourceUrl) {
  const url = post.sourceUrl.startsWith('http') ? post.sourceUrl : 'https://' + post.sourceUrl
  return Astro.redirect(url)
}
---

<BaseLayout title={post ? `${post.title} — seiyuu.db` : 'Not Found — seiyuu.db'}>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  {error || !post ? (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <h1 class='text-2xl font-medium'>{error || 'News post not found'}</h1>
    </div>
  ) : (
    <div class='max-w-2xl mx-auto px-6 py-10'>
      <a href='/news' class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'>
        <i class='ti ti-arrow-left text-base'></i>
        Back to news
      </a>

      <div class='flex items-center gap-2 mb-4'>
        <span class={`text-xs px-2.5 py-0.5 rounded-full font-medium ${categoryStyles[post.category ?? ''] ?? 'bg-neutral-800 text-neutral-400'}`}>
          {categoryLabel[post.category ?? ''] ?? 'Update'}
        </span>
        <span class='text-xs text-neutral-500'>{formattedDate}</span>
      </div>

      <h1 class='text-2xl font-medium leading-snug mb-6'>{post.title}</h1>

      {hasBody ? (
        <div class='text-sm text-neutral-300 leading-relaxed flex flex-col gap-4 mb-8'>
          {post.body.split('\n\n').map((paragraph) => <p class='whitespace-pre-wrap'>{paragraph}</p>)}
        </div>
      ) : null}

      {hasFbEmbed && (
        <a href={post.fbPostUrl!} target='_blank' rel='noopener noreferrer'
          class='mb-6 flex items-center gap-4 p-4 rounded-xl border border-neutral-800 bg-neutral-900/50 hover:border-neutral-600 transition-colors max-w-lg mx-auto w-full group'>
          <div class='w-12 h-12 rounded-lg bg-blue-600/20 flex items-center justify-center flex-shrink-0'>
            <svg class='w-6 h-6 text-blue-400' fill='currentColor' viewBox='0 0 24 24'>
              <path d='M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z'/>
            </svg>
          </div>
          <div class='flex-1 min-w-0'>
            <p class='text-sm font-medium text-neutral-200 group-hover:text-blue-400 transition-colors truncate'>{post.title}</p>
            <p class='text-xs text-neutral-500 mt-1'>View this post on Facebook →</p>
          </div>
        </a>
      )}

      {post.seiyuus?.length ? (
        <div class='border-t border-neutral-800 pt-5 mt-4'>
          <p class='text-xs text-neutral-500 mb-3'>Mentioned seiyuu</p>
          <div class='flex flex-wrap gap-2'>
            {post.seiyuus.map(s => (
              <a href={`/seiyuu/${s.id}`}
                class='flex items-center gap-3 border border-neutral-800 rounded-lg px-4 py-3 bg-neutral-900/50 hover:border-neutral-600 transition-colors'>
                <Avatar name={s.nameRomaji} imageUrl={s.imageUrl} size='md' />
                <div>
                  <div class='text-sm font-medium'>{s.nameRomaji}</div>
                  <div class='text-xs text-neutral-500'>{s.nameKanji}</div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ) : null}

      {post.sourceUrl && (
        <a href={post.sourceUrl.startsWith('http') ? post.sourceUrl : 'https://' + post.sourceUrl} target='_blank' rel='noopener noreferrer'
          class='inline-flex items-center gap-1.5 text-sm text-teal-400 hover:text-teal-300 border border-teal-800/50 bg-teal-950/30 px-4 py-2 rounded-md'>
          View original source
          <i class='ti ti-external-link text-base' />
        </a>
      )}
    </div>
  )}
</BaseLayout>
