---
export const prerender = false

import BaseLayout from '../../layouts/BaseLayout.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'

// mock data for now — will be replaced with a real fetch to /api/v1/news/:id
const post = {
	title: 'Kana Hanazawa cast as lead in upcoming Spring 2026 original anime',
	body: `The voice actress known for her emotionally nuanced performances will headline a new original series set to premiere this spring, marking her first lead role in two years.

Studio sources confirm the project has been in development since late 2024, with Hanazawa attached early in the casting process. The series, currently known only by its working title, is expected to be officially unveiled at an industry event later this summer.

This will be her first lead role in an original (non-adapted) anime since 2024, following a string of supporting roles across several major franchises.`,
	category: 'roles',
	seiyuuName: 'Kana Hanazawa',
	seiyuuSlug: 'kana-hanazawa',
	initials: 'KH',
	publishedAt: '2026-06-20',
	sourceUrl: null, // when available, shows an "external source" link button
}

const categoryStyles: Record<string, string> = {
	roles: 'bg-teal-900/50 text-teal-300',
	agency: 'bg-purple-900/50 text-purple-300',
}

const categoryLabel: Record<string, string> = {
	roles: 'Role announcement',
	agency: 'Agency news',
}

const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
	month: 'long',
	day: 'numeric',
	year: 'numeric',
})
---

<BaseLayout title={`${post.title} — seiyuu.db`}>
	<Nav slot='nav' />
	<NewsTicker slot='nav' />

	<div class='max-w-2xl mx-auto px-6 py-10'>
		<a
			href='/news'
			class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'
		>
			<i class='ti ti-arrow-left text-base'></i>
			Back to news
		</a>

		<div class='flex items-center gap-2 mb-4'>
			<span
				class={`text-xs px-2.5 py-0.5 rounded-full font-medium ${categoryStyles[post.category]}`}
			>
				{categoryLabel[post.category]}
			</span>
			<span class='text-xs text-neutral-500'>{formattedDate}</span>
		</div>

		<h1 class='text-2xl font-medium leading-snug mb-6'>{post.title}</h1>

		<a
			href={`/seiyuu/${post.seiyuuSlug}`}
			class='flex items-center gap-3 border border-neutral-800 rounded-lg px-4 py-3 mb-8 bg-neutral-900/50 hover:border-neutral-600 transition-colors w-fit'
		>
			<div
				class='w-10 h-10 rounded-full bg-teal-900/60 flex items-center justify-center text-sm font-medium text-teal-300 flex-shrink-0'
			>
				{post.initials}
			</div>
			<div>
				<div class='text-xs text-neutral-500'>Related seiyuu</div>
				<div class='text-sm font-medium'>{post.seiyuuName}</div>
			</div>
		</a>

		<div
			class='text-sm text-neutral-300 leading-relaxed flex flex-col gap-4 mb-8'
		>
			{post.body.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
		</div>

		{
			post.sourceUrl && (
				<a
					href={post.sourceUrl}
					target='_blank'
					rel='noopener noreferrer'
					class='inline-flex items-center gap-1.5 text-sm text-teal-400 hover:text-teal-300 border border-teal-800/50 bg-teal-950/30 px-4 py-2 rounded-md'
				>
					View original source
					<i class='ti ti-external-link text-base' />
				</a>
			)
		}
	</div>
</BaseLayout>
