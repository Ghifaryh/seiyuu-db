---
export const prerender = false
const apiBase = import.meta.env.API_URL || 'http://localhost:3001'

import BaseLayout from '../../layouts/BaseLayout.astro'
import Avatar from '../../components/Avatar.astro'
import Nav from '../../components/layout/Nav.astro'
import NewsTicker from '../../components/layout/NewsTicker.astro'

const { id } = Astro.params

interface Post {
  id: string
  title: string
  body: string
  category: string | null
  sourceUrl: string | null
  publishedAt: string | null
  seiyuu: { id: string; nameRomaji: string; nameKanji: string | null; imageUrl: string | null } | null
}

let post: Post | null = null
let error = ''

try {
  const res = await fetch(`${apiBase}/api/v1/news/${id}`)
  if (res.ok) post = await res.json()
  else error = 'News post not found'
} catch {
  error = 'Failed to load news post'
}

const categoryStyles: Record<string, string> = {
  roles: 'bg-teal-900/50 text-teal-300',
  agency: 'bg-purple-900/50 text-purple-300',
}
const categoryLabel: Record<string, string> = {
  roles: 'Role announcement',
  agency: 'Agency news',
}
const formattedDate = post?.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : ''

const hasBody = post?.body && post.body.trim().length > 0

if (post && !hasBody && post.sourceUrl) {
  const url = post.sourceUrl.startsWith('http') ? post.sourceUrl : 'https://' + post.sourceUrl
  return Astro.redirect(url)
}
---

<BaseLayout title={post ? `${post.title} — seiyuu.db` : 'Not Found — seiyuu.db'}>
  <Nav slot='nav' />
  <NewsTicker slot='nav' />

  {error || !post ? (
    <div class='max-w-3xl mx-auto px-6 py-10'>
      <h1 class='text-2xl font-medium'>{error || 'News post not found'}</h1>
    </div>
  ) : (
    <div class='max-w-2xl mx-auto px-6 py-10'>
      <a href='/news' class='inline-flex items-center gap-1.5 text-sm text-neutral-400 hover:text-neutral-200 mb-6'>
        <i class='ti ti-arrow-left text-base'></i>
        Back to news
      </a>

      <div class='flex items-center gap-2 mb-4'>
        <span class={`text-xs px-2.5 py-0.5 rounded-full font-medium ${categoryStyles[post.category ?? ''] ?? 'bg-neutral-800 text-neutral-400'}`}>
          {categoryLabel[post.category ?? ''] ?? 'Update'}
        </span>
        <span class='text-xs text-neutral-500'>{formattedDate}</span>
      </div>

      <h1 class='text-2xl font-medium leading-snug mb-6'>{post.title}</h1>

      {post.seiyuu && (
        <a href={`/seiyuu/${post.seiyuu.id}`}
          class='flex items-center gap-3 border border-neutral-800 rounded-lg px-4 py-3 mb-8 bg-neutral-900/50 hover:border-neutral-600 transition-colors w-fit'>
          <Avatar name={post.seiyuu.nameRomaji} imageUrl={post.seiyuu.imageUrl} size='md' />
          <div>
            <div class='text-xs text-neutral-500'>Related seiyuu</div>
            <div class='text-sm font-medium'>{post.seiyuu.nameRomaji}</div>
          </div>
        </a>
      )}

      <div class='text-sm text-neutral-300 leading-relaxed flex flex-col gap-4 mb-8'>
        {post.body.split('\n\n').map((paragraph) => <p>{paragraph}</p>)}
      </div>

      {post.sourceUrl && (
        <a href={post.sourceUrl.startsWith('http') ? post.sourceUrl : 'https://' + post.sourceUrl} target='_blank' rel='noopener noreferrer'
          class='inline-flex items-center gap-1.5 text-sm text-teal-400 hover:text-teal-300 border border-teal-800/50 bg-teal-950/30 px-4 py-2 rounded-md'>
          View original source
          <i class='ti ti-external-link text-base' />
        </a>
      )}
    </div>
  )}
</BaseLayout>
