---
const navLinks = [
	{ label: 'Seiyuu', href: '/seiyuu' },
	{ label: 'Season', href: '/season' },
	{ label: 'Pairings', href: '/pairings' },
	{ label: 'News', href: '/news' },
]
const currentPath = Astro.url.pathname
---

<nav
	id='main-nav'
	class='flex items-center justify-between px-4 sm:px-7 h-[76px] border-b border-neutral-800 bg-neutral-950 sticky top-0 z-10 transition-transform duration-300'
>
	<a href='/' class='flex items-center gap-2.5 min-w-0'>
		<div
			class='w-[34px] h-[34px] rounded-lg bg-teal-600 flex items-center justify-center text-[10px] font-medium text-teal-50 flex-shrink-0'
		>
			seiyuu
		</div>
		<div>
			<div class='text-[17px] font-medium tracking-tight leading-none'>
				seiyuu<span class='text-teal-400'>.db</span>
			</div>
			<div class='hidden sm:block text-[11px] text-neutral-500 mt-0.5'>
				voice actor database
			</div>
		</div>
	</a>

	<!-- desktop links -->
	<div class='hidden md:flex gap-1'>
		{
			navLinks.map((link) => {
				const isActive = currentPath === link.href
				const linkClass = isActive
					? 'text-sm font-medium px-3.5 py-2 rounded-md text-teal-300 bg-teal-900/40'
					: 'text-sm font-medium px-3.5 py-2 rounded-md text-neutral-400 hover:bg-neutral-900'
				return (
					<a href={link.href} class={linkClass}>
						{link.label}
					</a>
				)
			})
		}
	</div>

	<div class='flex items-center gap-2'>
		<!-- <button
			class='text-sm px-3 sm:px-4.5 py-2 sm:py-2.5 rounded-md border border-neutral-700 text-white font-medium hover:bg-neutral-900'
			id='nav-login-btn'
		>
			Log in
		</button> -->

		<!-- mobile hamburger -->
		<button
			id='menu-toggle'
			class='md:hidden w-9 h-9 flex items-center justify-center rounded-md hover:bg-neutral-900 flex-shrink-0 text-white'
			aria-label='Toggle menu'
		>
			<i class='ti ti-menu-2 text-2xl text-white'></i>
		</button>
	</div>
</nav>

<!-- mobile dropdown menu -->
<div
	id='mobile-menu'
	class='hidden md:!hidden flex-col border-b border-neutral-800 bg-neutral-950 px-4 py-3 gap-1'
>
	{
		navLinks.map((link) => {
			const isActive = currentPath === link.href
			const linkClass = isActive
				? 'text-sm font-medium px-3.5 py-2.5 rounded-md text-teal-300 bg-teal-900/40'
				: 'text-sm font-medium px-3.5 py-2.5 rounded-md text-neutral-400 hover:bg-neutral-900'
			return (
				<a href={link.href} class={linkClass}>
					{link.label}
				</a>
			)
		})
	}
	<!-- <button
		class='text-sm px-3.5 py-2.5 rounded-md border border-neutral-700 text-white font-medium hover:bg-neutral-900 mt-1 text-left'
	>
		Log in
	</button> -->
</div>

<script>
	let lastScrollY = window.scrollY
	const nav = document.getElementById('main-nav')

	function handleScroll() {
		const currentScrollY = window.scrollY
		if (!nav) return

		if (currentScrollY < 80) {
			nav.style.transform = 'translateY(0)'
			lastScrollY = currentScrollY
			return
		}

		if (currentScrollY > lastScrollY) {
			nav.style.transform = 'translateY(-100%)'
		} else {
			nav.style.transform = 'translateY(0)'
		}

		lastScrollY = currentScrollY
	}

	window.addEventListener('scroll', handleScroll, { passive: true })

	const menuToggle = document.getElementById('menu-toggle')
	const mobileMenu = document.getElementById('mobile-menu')
	// const navLoginBtn = document.getElementById('nav-login-btn')

	menuToggle?.addEventListener('click', () => {
		mobileMenu?.classList.toggle('hidden')
		mobileMenu?.classList.toggle('flex')
		// navLoginBtn?.classList.toggle('hidden')
	})
</script>
