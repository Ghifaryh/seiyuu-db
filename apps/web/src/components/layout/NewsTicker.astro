---
const newsItems = [
	{
		icon: '🎤',
		text: 'Kana Hanazawa cast as lead in upcoming Spring 2026 original anime',
	},
	{ icon: '🏢', text: 'Yoshitsugu Matsuoka renews contract with Pro-Fit' },
	{
		icon: '🎤',
		text: 'Aoi Yuuki announced for lead role in Summer 2026 NHK series',
	},
	{
		icon: '🏢',
		text: 'Hiroshi Kamiya joins new agency following contract renewal',
	},
]
---

<a
	href='/news'
	class='block bg-teal-950/40 border-b border-teal-800/40 px-6 py-2 overflow-hidden hover:bg-teal-950/60 transition-colors'
>
	<div class='flex items-center gap-4'>
		<span
			class='text-xs font-medium px-2.5 py-1 rounded-full bg-teal-600 text-teal-50 whitespace-nowrap flex-shrink-0'
		>
			News
		</span>

		<div class='ticker-track flex-1 overflow-hidden'>
			<div class='ticker-content flex gap-10 whitespace-nowrap'>
				{
					newsItems.map((item) => (
						<span class='text-sm text-teal-200 flex items-center gap-2'>
							<span>{item.icon}</span> {item.text}
						</span>
					))
				}
				<!-- duplicate set for seamless loop -->
				{
					newsItems.map((item) => (
						<span class='text-sm text-teal-200 flex items-center gap-2'>
							<span>{item.icon}</span> {item.text}
						</span>
					))
				}
			</div>
		</div>
	</div>
</a>

<style>
	.ticker-track {
		mask-image: linear-gradient(to right, black 95%, transparent 100%);
	}

	.ticker-content {
		animation: ticker-scroll 30s linear infinite;
	}

	.ticker-content:hover {
		animation-play-state: paused;
	}

	@media (max-width: 640px) {
		.ticker-content {
			animation-duration: 3s;
		}
	}

	@keyframes ticker-scroll {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-50%);
		}
	}
</style>
