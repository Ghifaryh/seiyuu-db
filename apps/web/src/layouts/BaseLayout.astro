---
import '../styles/global.css'

interface Props {
	title?: string
}

const { title = 'seiyuu.db' } = Astro.props
---

<!doctype html>
<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width' />
		<title>{title}</title>
	</head>
	<body class='bg-neutral-950 text-white min-h-screen'>
		<slot name='nav' />
		<main>
			<slot />
		</main>
	</body>
</html>
