---
import '../styles/global.css'

interface Props {
	title?: string
	description?: string
	ogImage?: string
}

const { title = 'seiyuu.db', description, ogImage } = Astro.props
const desc = description || 'A seiyuu-focused database and discovery site. Search Japanese voice actors by kanji, romaji, or any name order.'
---

<!doctype html>
<html lang='en'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width' />
		<title>{title}</title>
		<meta name='description' content={desc} />
		<meta property='og:title' content={title} />
		<meta property='og:description' content={desc} />
		<meta property='og:type' content='website' />
		<meta property='og:site_name' content='seiyuu.db' />
		{ogImage ? (
			<meta property='og:image' content={ogImage} />
		) : (
			<meta property='og:image' content='https://seiyuu-db.gehu.me/favicon.svg' />
		)}
		<meta name='twitter:card' content='summary' />
	</head>
	<body class='bg-neutral-950 text-white min-h-screen'>
		<slot name='nav' />
		<main>
			<slot />
		</main>
	</body>
</html>
